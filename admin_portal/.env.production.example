# ==============================================
# LOKMA Admin Portal - Production Environment Variables
# ==============================================
# Bu dosya referans icin tum gerekli env var'lari listeler.
# Gercek degerler Vercel Dashboard veya .env.local'da saklanir.
# Bu dosya git'e COMMIT edilir (degerler olmadan).
#
# Vercel'e eklemek icin (newline OLMADAN):
#   printf 'DEGER' | npx vercel env add DEGISKEN_ADI production
# ==============================================

# Firebase Client SDK
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Stripe (Test veya Live Mode)
NEXT_PUBLIC_USE_STRIPE_TEST_MODE=

# Email Service (Resend)
RESEND_API_KEY=

# Google Maps (opsiyonel)
